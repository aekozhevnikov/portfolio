{
    "name": "portfolio",
    "version": "1.0.0",
    "description": "Personal portfolio website built with Quasar",
    "author": "Anton Kozhevnikov",
    "type": "module",
    "private": true,
    "scripts": {
        "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
        "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
        "test": "node --no-deprecation ./node_modules/jest/bin/jest.js",
        "dev": "quasar dev",
        "build": "quasar build",
        "build:gh-pages": "quasar build",
        "postinstall": "quasar prepare",
        "deploy": "gh-pages -d dist"
    },
    "dependencies": {
        "@quasar/extras": "^1.16.4",
        "@supabase/supabase-js": "^2.98.0",
        "html2pdf.js": "^0.14.0",
        "pdfmake": "^0.3.3",
        "pinia": "^2.3.0",
        "quasar": "^2.16.0",
        "vue": "^3.4.18",
        "vue-i18n": "^11.2.8",
        "vue-router": "^4.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.14.0",
        "@quasar/app-vite": "^2.2.1",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/user-event": "^14.5.2",
        "@testing-library/vue": "^8.0.0",
        "@types/node": "^20.5.9",
        "@types/pdfmake": "^0.3.0",
        "@vue/eslint-config-prettier": "^10.1.0",
        "@vue/eslint-config-typescript": "^14.1.3",
        "@vue/test-utils": "^2.4.4",
        "@vue/vue3-jest": "^29.0.0",
        "autoprefixer": "^10.4.2",
        "eslint": "^9.14.0",
        "eslint-plugin-vue": "^9.30.0",
        "gh-pages": "^6.3.0",
        "globals": "^15.12.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "prettier": "^3.3.3",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "~5.5.3",
        "vite-plugin-checker": "^0.8.0",
        "vue-tsc": "^2.0.29"
    },
    "engines": {
        "node": "^28 || ^26 || ^24 || ^23 || ^22 || ^21 || ^20 || ^18",
        "npm": ">= 6.13.4",
        "yarn": ">= 1.21.1"
    }
}
